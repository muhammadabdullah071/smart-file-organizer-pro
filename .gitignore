# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml

# IDE / Editor
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Runtime artifacts (logs, reports, manifests are generated at runtime)
logs/*
!logs/.gitkeep
reports/*
!reports/.gitkeep
.sfop/manifests/*
!.sfop/manifests/.gitkeep

# Local config overrides (keep committed default config.json)
config.local.json
